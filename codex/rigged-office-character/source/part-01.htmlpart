<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Rigged 2D Office Character Demo</title>
<style>
  :root{
    --bg:#efe5c6;
    --panel:#171717;
    --panel-2:#242424;
    --text:#f8f8f8;
    --muted:#b7b7b7;
    --accent:#7b61ff;
    --accent-2:#26d0ce;
    --line:#101010;
  }
  *{box-sizing:border-box}
  html,body{height:100%}
  body{
    margin:0;
    font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
    background:#111;
    color:var(--text);
    overflow:hidden;
  }
  .app{
    position:relative;
    height:100%;
    display:grid;
    grid-template-columns:minmax(0,1fr) 330px;
  }
  .stage-wrap{
    position:relative;
    min-width:0;
    --cam-scale:1;
    --cam-x:0px;
    --cam-y:0px;
    background:
      radial-gradient(circle at 70% 18%, rgba(255,255,255,.55), transparent 28%),
      linear-gradient(#f6edcf 0 70%, #d7b676 70% 100%);
    overflow:hidden;
  }
  .stage-wrap::before{
    content:"";
    position:absolute;
    left:0;right:0;bottom:0;
    height:28%;
    background:
      linear-gradient(90deg,rgba(0,0,0,.04) 1px,transparent 1px),
      linear-gradient(rgba(0,0,0,.04) 1px,transparent 1px);
    background-size:44px 44px;
    transform:skewX(-10deg) scale(1.2);
    transform-origin:bottom;
  }
  .office{
    position:absolute;
    inset:0;
    pointer-events:none;
    opacity:.9;
  }
  .camera-rig{
    position:absolute;
    inset:0;
    transform-origin:50% 78%;
    transform:translate(var(--cam-x),var(--cam-y)) scale(var(--cam-scale));
    transition:transform .7s cubic-bezier(.2,.7,.15,1);
  }
  .director-hud{
    position:absolute;
    right:18px;
    top:18px;
    z-index:8;
    min-width:190px;
    padding:10px 12px;
    border-radius:16px;
    background:rgba(15,15,15,.75);
    backdrop-filter:blur(12px);
    border:1px solid rgba(255,255,255,.08);
    box-shadow:0 10px 30px rgba(0,0,0,.22);
  }
  .director-kicker{
    font-size:10px;
    letter-spacing:.16em;
    text-transform:uppercase;
    color:#bfbfbf;
    margin-bottom:4px;
  }
  .director-title{
    font-weight:800;
    font-size:14px;
    color:#fff;
  }
  .director-sub{
    margin-top:2px;
    color:#c9c9c9;
    font-size:12px;
  }
  .scene-props{
    position:absolute;
    inset:0;
    pointer-events:none;
    opacity:0;
    transition:opacity .35s;
  }
  .stage-wrap[data-scene="meeting"] .meeting-props,
  .stage-wrap[data-scene="cafe"] .cafe-props,
  .stage-wrap[data-scene="studio"] .studio-props{opacity:1}
  .stage-wrap[data-scene="meeting"]{
    background:radial-gradient(circle at 70% 16%, rgba(255,255,255,.65), transparent 28%),linear-gradient(#edf5f9 0 69%, #b8cad5 69% 100%);
  }
  .stage-wrap[data-scene="cafe"]{
    background:radial-gradient(circle at 72% 15%, rgba(255,255,255,.55), transparent 25%),linear-gradient(#fff1d7 0 69%, #d6a970 69% 100%);
  }
  .stage-wrap[data-scene="studio"]{
    background:radial-gradient(circle at 50% 12%, rgba(255,255,255,.6), transparent 22%),linear-gradient(#efefef 0 69%, #c9c9c9 69% 100%);
  }
  .meeting-window{
    position:absolute;left:8%;top:13%;width:28%;height:24%;
    border:8px solid #a9bcc7;border-radius:10px;
    background:linear-gradient(#e8f7ff,#d8edf5);box-shadow:0 8px 20px rgba(0,0,0,.08);
  }
  .meeting-window::before,.meeting-window::after{content:"";position:absolute;background:#a9bcc7}
  .meeting-window::before{left:48%;top:0;bottom:0;width:6px}
  .meeting-window::after{left:0;right:0;top:48%;height:6px}
  .meeting-plant{position:absolute;left:11%;bottom:19%;width:12%;height:18%;}
  .meeting-plant .pot{position:absolute;left:18%;bottom:0;width:64%;height:32%;background:#91633b;border-radius:6px 6px 12px 12px}
  .meeting-plant .leaf{position:absolute;bottom:24%;width:18%;height:48%;background:#4d8a5d;border-radius:100px 100px 0 100px;transform-origin:bottom center}
  .meeting-plant .l1{left:8%;transform:rotate(-26deg)} .meeting-plant .l2{left:28%;height:58%;transform:rotate(-6deg)}
  .meeting-plant .l3{left:49%;height:54%;transform:rotate(12deg)} .meeting-plant .l4{left:67%;height:45%;transform:rotate(28deg)}
  .cafe-shelf{position:absolute;left:10%;top:16%;width:44%;height:10px;background:#bd7a3a;box-shadow:0 4px 0 #8b5729,0 34px 0 #bd7a3a,0 38px 0 #8b5729}
  .cafe-cup{position:absolute;top:-14px;width:22px;height:18px;background:#fff5e7;border:3px solid #9e6d43;border-radius:0 0 8px 8px}
  .cafe-cup::after{content:"";position:absolute;right:-9px;top:2px;width:8px;height:10px;border:3px solid #9e6d43;border-left:0;border-radius:0 8px 8px 0}
  .cafe-counter{position:absolute;left:7%;right:7%;bottom:15%;height:18%;background:linear-gradient(#c27b3a,#aa662d);border-top:8px solid #7b431f}
  .cafe-counter::before{content:"";position:absolute;inset:auto 0 0 0;height:60%;background:repeating-linear-gradient(90deg,rgba(255,255,255,.18) 0 3px,transparent 3px 24px)}
  .studio-light{position:absolute;top:10%;width:6%;height:12%;background:#2b2b2b;border-radius:8px;box-shadow:0 0 30px rgba(255,255,255,.35)}
  .studio-light.left{left:16%} .studio-light.right{right:16%}
  .studio-light::before{content:"";position:absolute;left:46%;bottom:100%;width:4px;height:34px;background:#2b2b2b}
  .studio-tripod{position:absolute;left:12%;bottom:16%;width:15%;height:28%}
  .studio-tripod .cam{position:absolute;left:20%;top:0;width:52%;height:28%;background:#1f1f1f;border-radius:8px}
  .studio-tripod .cam::after{content:"";position:absolute;right:-12px;top:8px;border:10px solid transparent;border-left-color:#1f1f1f}
  .studio-tripod .leg{position:absolute;left:45%;top:24%;width:5px;height:60%;background:#1f1f1f;transform-origin:top center}
  .studio-tripod .leg.l1{transform:rotate(-18deg)} .studio-tripod .leg.l2{transform:rotate(0deg)} .studio-tripod .leg.l3{transform:rotate(18deg)}
  .studio-chair{position:absolute;right:11%;bottom:18%;width:16%;height:20%}
  .studio-chair .seat{position:absolute;left:16%;bottom:20%;width:58%;height:20%;background:#c56a30;border-radius:6px}
  .studio-chair .back{position:absolute;left:22%;bottom:42%;width:46%;height:28%;background:#c56a30;border-radius:6px}
  .studio-chair .x1,.studio-chair .x2{position:absolute;left:45%;bottom:6%;width:4px;height:62%;background:#64351b;transform-origin:bottom center}
  .studio-chair .x1{transform:rotate(32deg)} .studio-chair .x2{transform:rotate(-32deg)}
  .board{
    position:absolute;
    right:5%;
    top:12%;
    width:25%;
    height:25%;
    background:#b87d43;
    border:8px solid #8b5729;
    box-shadow:0 10px 30px rgba(0,0,0,.15);
  }
  .paper{position:absolute;background:#fff;border-radius:2px;box-shadow:0 2px 4px rgba(0,0,0,.15)}
  .paper.p1{left:10%;top:16%;width:35%;height:48%;transform:rotate(-2deg)}
  .paper.p2{right:9%;top:10%;width:28%;height:30%;transform:rotate(3deg)}
  .paper.p3{right:14%;bottom:8%;width:40%;height:26%;transform:rotate(-1deg)}
  .desk{
    position:absolute;
    right:4%;
    bottom:16%;
    width:48%;
    height:7.5%;
    background:#dcad70;
    border:6px solid #9f6c3d;
  }
  .desk::after{
    content:"";
    position:absolute;
    top:100%;
    right:6%;
    width:10%;
    height:160px;
    background:#3a302b;
  }
  .monitor{
    position:absolute;
    right:18%;
    bottom:24%;
    width:24%;
    height:22%;
    background:#1e1e1e;
    border:7px solid #111;
    border-radius:6px;
    transform:skewY(-2deg);
  }
  .monitor::after{
    content:"";
    position:absolute;
    left:45%;top:100%;
    width:12%;height:80px;
    background:#757575;
    border:4px solid #222;
  }
  #character-svg{
    position:absolute;
    left:41%;
    bottom:4%;
    width:min(40vw,470px);
    height:auto;
    transform:translateX(-56%);
    overflow:visible;
    z-index:2;
  }
  #character-svg-secondary{
    position:absolute;
    left:24%;
    bottom:4%;
    width:min(34vw,390px);
    height:auto;
    transform:translateX(-50%);
    overflow:visible;
    z-index:2;
    opacity:0;
    pointer-events:none;
    transition:opacity .3s ease, left .45s ease, transform .45s ease, bottom .45s ease, width .45s ease;
  }
  .stage-wrap.duo-active #character-svg-secondary{opacity:1}
  .chair{
    position:absolute;
    left:76%;
    right:auto;
    bottom:18%;
    width:15%;
    height:21%;
    transform:translateX(-50%);
    opacity:0;
    transition:opacity .18s;
    z-index:1;
    pointer-events:none;
  }
  .chair::before{
    content:"";
    position:absolute;
    right:4%;
    bottom:14%;
    width:70%;
    height:76%;
    background:#1e56a8;
    border:5px solid #16396a;
    border-radius:14px 14px 18px 18px;
  }
  .chair::after{
    content:"";
    position:absolute;
    left:12%;
    bottom:0;
    width:60%;
    height:24%;
    background:#184a95;
    border:5px solid #16396a;
    border-radius:18px 18px 10px 10px;
  }
  .desk-front-mask{
    position:absolute;
    right:4%;
    bottom:16%;
    width:48%;
    height:7.5%;
    background:#dcad70;
    border:6px solid #9f6c3d;
    opacity:0;
    z-index:3;
    pointer-events:none;
    transition:opacity .18s;
  }
  .desk-front-mask::after{
    content:"";
    position:absolute;
    top:100%;
    right:6%;
    width:10%;
    height:160px;
    background:#3a302b;
  }
  .stage-wrap.sitting-mode .chair,
  .stage-wrap.sitting-mode .desk-front-mask{
    opacity:1;
  }
  .hud{
    position:absolute;
    left:20px;
    top:20px;
    display:flex;
    gap:10px;
    align-items:center;
    padding:10px 14px;
    border-radius:999px;
    background:rgba(15,15,15,.72);
    backdrop-filter:blur(12px);
    font-size:13px;
    z-index:5;
  }
  .dot{width:9px;height:9px;border-radius:50%;background:#2bd576;box-shadow:0 0 12px #2bd576}
  .speech{
    position:fixed;
    left:var(--speech-left, 50vw);
    top:var(--speech-top, 92px);
    transform:translateX(-50%);
    width:min(var(--speech-max-width, 640px), calc(100vw - 24px));
    background:#0a0a0a;
    color:#fff;
    font-size:clamp(20px,3vw,42px);
    font-weight:800;
    line-height:1.1;
