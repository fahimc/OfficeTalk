      return Number.isFinite(n) ? n : fallback;
    }
    return fallback;
  }

  function getMainStageLeftPercent(){
    return state === 'sit' ? 76 : 41;
  }

  function resolveSecondaryLeftPercent(){
    const mainLeft = getMainStageLeftPercent();
    let secLeft = parseStagePercent(secondaryStage.left, 26);
    const minGap = secondaryStage.minGap || 24;
    if(Math.abs(secLeft - mainLeft) < minGap){
      secLeft = secLeft <= mainLeft ? mainLeft - minGap : mainLeft + minGap;
    }
    return Math.max(12, Math.min(88, secLeft));
  }

  function setSecondaryMotion(name){ secondaryMotion = name; }
  function setSecondaryStage(opts = {}){ secondaryStage = { ...secondaryStage, ...opts }; }
  function showSecondary(flag){
    stage.classList.toggle('duo-active', !!flag);
    secondaryStage.visible = !!flag;
  }

  function renderSecondaryRig(t){
    const speed = Number(speedInput.value);
    const s = t * 0.001 * speed;
    const p = secondaryParts;
    const breathe = Math.sin(s * 2.05);

    const resolvedLeft = resolveSecondaryLeftPercent();
    secondarySvg.style.left = `${resolvedLeft}%`;
    secondarySvg.style.bottom = secondaryStage.bottom;
    const mainWidth = getComputedStyle(svg).width || '320px';
    const widthScale = secondaryStage.widthScale || 1;
    secondarySvg.style.width = `calc(${mainWidth} * ${widthScale})`;
    secondarySvg.style.opacity = secondaryStage.visible ? '1' : '0';
    const secondaryScale = (secondaryStage.matchHeight ? mainPoseScale : 1) * (secondaryStage.scale || 1);
    secondarySvg.style.transform = `translateX(-50%) scale(${secondaryScale})${secondaryStage.flip ? ' scaleX(-1)' : ''}`;

    tr(p.head,0,0,0,1,1,'243px','340px');
    tr(p.torso,0,0,0,1,1,'243px','352px');
    tr(p.frontArm,0,0,0,1,1,'285px','365px');
    tr(p.backArm,0,0,0,1,1,'200px','365px');
    tr(p.frontUpper,0,0,0,1,1,'285px','365px');
    tr(p.frontFore,0,0,0,1,1,'327px','423px');
    tr(p.legLeft,0,0,0,1,1,'220px','574px');
    tr(p.legRight,0,0,0,1,1,'264px','574px');
    tr(p.leftThigh,0,0,0,1,1,'220px','574px');
    tr(p.leftShin,0,0,0,1,1,'214px','648px');
    tr(p.rightThigh,0,0,0,1,1,'264px','574px');
    tr(p.rightShin,0,0,0,1,1,'270px','648px');

    p.browLeft.setAttribute('d','M196 198 Q212 190 228 196');
    p.browRight.setAttribute('d','M257 196 Q272 190 287 198');
    p.lidLeft.style.opacity = '0';
    p.lidRight.style.opacity = '0';
    p.pupils.style.transformOrigin = '245px 234px';

    rootSetMouth(secondarySvg, 'rest');
    tr(p.torso, 0, breathe * 1.4, 0, 1, 1 + breathe * 0.003, '243px', '352px');
    tr(p.head, 0, breathe * 1.0, Math.sin(s * 1.1) * 0.8, 1, 1, '243px', '340px');
    tr(p.backArm, 0, 0, 7 + Math.sin(s * 1.2) * 1.2, 1, 1, '200px', '365px');
    tr(p.frontUpper, 0, 0, -10, 1, 1, '285px', '365px');
    tr(p.frontFore, 0, 0, 15, 1, 1, '327px', '423px');

    if(secondaryMotion === 'talk'){
      tr(p.head, 0, 0, Math.sin(s * 2.8) * 1.3, 1, 1, '243px', '340px');
      tr(p.frontUpper, 0, 0, -18 + Math.sin(s * 3.1) * 5, 1, 1, '285px', '365px');
      tr(p.frontFore, 0, 0, 28 + Math.sin(s * 4.2) * 10, 1, 1, '327px', '423px');
      tr(p.backArm, 0, 0, 12 + Math.sin(s * 2.1) * 3, 1, 1, '200px', '365px');
      rootSetMouth(secondarySvg, Math.sin(s * 8.2) > 0 ? 'A' : 'E');
    }
    if(secondaryMotion === 'think'){
      tr(p.head, 0, 0, 6, 1, 1, '243px', '340px');
      tr(p.frontUpper, 0, 0, -56, 1, 1, '285px', '365px');
      tr(p.frontFore, 0, 0, 136, 1, 1, '327px', '423px');
      p.browLeft.setAttribute('d','M196 201 Q212 185 228 193');
      p.browRight.setAttribute('d','M257 197 Q272 191 287 199');
      rootSetMouth(secondarySvg, 'M');
    }
    if(secondaryMotion === 'angry'){
      tr(p.frontUpper, 0, 0, 8, 1, 1, '285px', '365px');
      tr(p.frontFore, 0, 0, 24, 1, 1, '327px', '423px');
      tr(p.backArm, 0, 0, -4, 1, 1, '200px', '365px');
      p.browLeft.setAttribute('d','M196 186 L228 198');
      p.browRight.setAttribute('d','M257 198 L287 186');
      rootSetMouth(secondarySvg, 'frown');
    }
    if(secondaryMotion === 'point'){
      tr(p.frontUpper, 0, 0, -55, 1, 1, '285px', '365px');
      tr(p.frontFore, 0, 0, -92, 1, 1, '327px', '423px');
      tr(p.backArm, 0, 0, 18, 1, 1, '200px', '365px');
    }
    if(secondaryMotion === 'wave'){
      tr(p.frontUpper, 0, 0, -40, 1, 1, '285px', '365px');
      tr(p.frontFore, 0, 0, -188 + Math.sin(s * 7.5) * 15, 1, 1, '327px', '423px');
      rootSetMouth(secondarySvg, 'smile');
    }

    tr(p.pupils, secondaryStage.flip ? 8 : -8, -1, 0, 1, 1, '245px', '234px');
  }


  let activeScene = 'office';
  let activeCamera = 'medium';
  let activeCameraLabel = 'Medium shot';
  let directorTimers = [];
  let directorDemoRunning = false;

  const sceneNames = {
    office: 'Office',
    meeting: 'Meeting room',
    cafe: 'Cafe',
    studio: 'Studio set'
  };

  const cameraPresets = {
    wide: { label: 'Wide shot', scale: 0.92, x: 0, y: 0 },
    medium: { label: 'Medium shot', scale: 1.05, x: 18, y: 6 },
    close: { label: 'Close-up', scale: 1.58, x: 118, y: 42 },
    overshoulder: { label: 'Over-shoulder', scale: 1.24, x: 84, y: 16 }
  };

  function updateDirectorUI(note = 'ready for blocking'){
    const sceneLabel = sceneNames[activeScene] || activeScene;
    const cameraLabel = activeCameraLabel || cameraPresets[activeCamera]?.label || activeCamera;
    directorShot.textContent = cameraLabel;
    directorStatus.textContent = `${sceneLabel} • ${note}`;
    shotReadout.innerHTML = `scene: ${sceneLabel}<br>camera: ${cameraLabel}<br>shot: ${note}`;
  }

  function setScene(name, note){
    activeScene = name;
    stage.dataset.scene = name;
    document.querySelectorAll('[data-scene]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.scene === name);
    });
    updateDirectorUI(note || 'set dressed');
  }

  function setCamera(name, note){
    const preset = cameraPresets[name] || cameraPresets.medium;
    activeCamera = name;
    activeCameraLabel = preset.label;
    stage.style.setProperty('--cam-scale', preset.scale);
    stage.style.setProperty('--cam-x', `${preset.x}px`);
    stage.style.setProperty('--cam-y', `${preset.y}px`);
    document.querySelectorAll('[data-camera]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.camera === name);
    });
    updateDirectorUI(note || 'camera locked');
  }

  function setCameraCustom(label, scale, x, y, note, activeButton = 'close'){
    activeCamera = activeButton;
    activeCameraLabel = label;
    stage.style.setProperty('--cam-scale', scale);
    stage.style.setProperty('--cam-x', `${x}px`);
    stage.style.setProperty('--cam-y', `${y}px`);
    document.querySelectorAll('[data-camera]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.camera === activeButton);
    });
    updateDirectorUI(note || 'camera locked');
  }

  function clearDirectorTimers(){
    directorTimers.forEach(id => clearTimeout(id));
    directorTimers = [];
  }

  function cue(delay, fn){
    const id = setTimeout(fn, delay);
    directorTimers.push(id);
  }

  function rootSetMouth(root, name){
    root.querySelectorAll('.mouth-shape').forEach(el => {
      el.classList.toggle('active', el.dataset.mouth === name);
    });
  }

  function showDirectorLine(text, speaker = 'center'){
    positionSpeechBubble();
    speechBubble.textContent = text;
    speechBubble.classList.remove('speaker-left','speaker-right','speaker-center');
    speechBubble.classList.add('speaker-center');
    speechBubble.classList.add('visible');
  }

  function stopDemoScene(resetNote = 'demo stopped'){
    clearDirectorTimers();
    directorDemoRunning = false;
    speechBubble.classList.remove('visible','speaker-left','speaker-right');
    speechBubble.classList.add('speaker-center');
    showSecondary(false);
    setSecondaryMotion('idle');
    setSecondaryStage({ left: '26%', bottom: '4%', scale: 1, widthScale: 1, matchHeight: true, flip: false });
    setMotion('idle');
    updateDirectorUI(resetNote);
  }

  function playDemoScene(){
    clearDirectorTimers();
    stopSpeaking();
    directorDemoRunning = true;
    showSecondary(true);

    // Main character: manager on the right.
    custom.characterType = 'female';
    custom.hairStyle = 'ponytail';
    custom.outfitStyle = 'dress';
    custom.beardStyle = 'none';
    custom.skin = '#f2dfd1';
    custom.hair = '#a56b29';
    custom.outfit = '#342a8a';
    custom.secondary = '#fbfbfb';
    custom.accent = '#ef6d4f';
    applyCustomization();

    // Secondary character: employee on the left.
    secondaryLook = {
      characterType: 'male',
      skin: '#ddb695',
      hair: '#5b3a1f',
      outfit: '#1f6d57',
      secondary: '#f5e9d6',
      accent: '#f2c94c',
      hairStyle: 'buzz',
      outfitStyle: 'blazer',
      beardStyle: 'stubble'
    };
    applyLookToSvg(secondarySvg, secondaryLook);

    setScene('office', 'shot 1 · two shot set-up');
    setCamera('wide', 'shot 1 · two shot set-up');
    setMotion('sit');
    setSecondaryMotion('think');
    setSecondaryStage({ left: '24%', bottom: '4%', scale: 1, widthScale: 1, matchHeight: true, flip: false });
    showDirectorLine('Could we talk about my performance review?', 'left');

    cue(2100, () => {
      setCameraCustom('Manager medium', 1.18, 56, 12, 'shot 2 · push in on the manager', 'medium');
      setMotion('talk');
      setSecondaryMotion('idle');
      showDirectorLine('Absolutely. You have done strong work this quarter.', 'right');
    });

    cue(4700, () => {
      setCameraCustom('Employee close-up', 1.55, -112, 36, 'shot 3 · close-up on the employee', 'close');
      setMotion('sit');
      setSecondaryMotion('talk');
      showDirectorLine('Thank you. I am ready for more responsibility.', 'left');
    });

    cue(7600, () => {
      setCameraCustom('Two shot', 1.04, 0, 2, 'shot 4 · return to the two shot', 'wide');
      setSecondaryMotion('point');
      setMotion('surprised');
